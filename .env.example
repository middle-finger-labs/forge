# =============================================================================
# Forge — Environment Configuration
# =============================================================================
# Copy to .env and fill in your values:  cp .env.example .env
# The setup.sh script will auto-generate secrets marked [auto] if left blank.

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_USER=forge
POSTGRES_PASSWORD=forge_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=forge_app

# Full connection string (used by app services inside Docker)
# Override only if you have an external database.
# DATABASE_URL=postgresql://forge:forge_dev_password@postgres:5432/forge_app

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Temporal
# ---------------------------------------------------------------------------
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=forge-main

# ---------------------------------------------------------------------------
# Auth (Better Auth)
# ---------------------------------------------------------------------------
# [auto] Random 32-byte secret for signing sessions/tokens
BETTER_AUTH_SECRET=
# Public URL where the auth service is reachable
BETTER_AUTH_URL=http://localhost:3100

# Default admin account created by seed.ts
FORGE_ADMIN_EMAIL=admin@example.com
FORGE_ADMIN_PASSWORD=changeme123

# ---------------------------------------------------------------------------
# Org Secrets Encryption (Fernet)
# ---------------------------------------------------------------------------
# [auto] Generated by: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FORGE_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# LLM API Keys
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional — for embedding models or GPT fallback)
# OPENAI_API_KEY=sk-...

# ---------------------------------------------------------------------------
# Langfuse (LLM observability — optional, enable with --profile observability)
# ---------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_URL=http://localhost:3001
LANGFUSE_SECRET=forge-langfuse-dev-secret
LANGFUSE_SALT=forge-langfuse-dev-salt

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
LOG_LEVEL=info
ENVIRONMENT=development

# GitHub (optional — for repo operations)
# GITHUB_TOKEN=ghp_...
