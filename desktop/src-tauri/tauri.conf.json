{
  "$schema": "https://raw.githubusercontent.com/nickkraakman/tauri-v2-schema/refs/heads/main/tauri.conf.schema.json",
  "productName": "Forge",
  "identifier": "com.middlefingerlabs.forge",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": null,
      "frameworks": []
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "category": "DeveloperTool",
    "shortDescription": "Forge — conversational agent interface",
    "longDescription": "Forge Desktop is a native conversational interface for managing AI agent pipelines. Chat with agents, run pipelines, review approvals, and monitor costs — all from your desktop.",
    "copyright": "Copyright (c) 2024 Middle Finger Labs",
    "externalBin": []
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Forge",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' wss://* ws://* https://* http://*; img-src 'self' https://* data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "notification": {
      "enabled": true
    },
    "window-state": {
      "enabled": true
    },
    "global-shortcut": {
      "enabled": true
    },
    "autostart": {
      "enabled": true
    }
  }
}
