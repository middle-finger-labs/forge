{
  "identifier": "default",
  "description": "Default capabilities for the main Forge window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "notification:default",
    "os:default",
    "biometric:default",
    "haptics:default",
    "deep-link:default",
    "shell:default",
    "window-state:allow-restore-state",
    "window-state:allow-save-window-state",
    "global-shortcut:default",
    "autostart:default"
  ]
}
