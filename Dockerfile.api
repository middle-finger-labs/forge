# Forge API server
FROM python:3.12-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY pyproject.toml .
RUN pip install --no-cache-dir . && pip install --no-cache-dir email-validator

COPY . .

# Railway sets PORT dynamically; default 8000 for local Docker Compose
ENV PORT=8000
EXPOSE ${PORT}

CMD uvicorn api.server:app --host 0.0.0.0 --port ${PORT} --workers 2
